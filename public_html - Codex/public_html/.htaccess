ErrorDocument 404 /404.html

RewriteEngine On

# Do not expose source files directly in production
RewriteRule ^src/ - [F,L,NC]
RewriteRule ^assets/js/app\.src\.js$ - [F,L,NC]
RewriteRule ^test-results(?:/.*)?$ - [F,L,NC]
RewriteRule ^escala-teste(?:/.*)?$ https://datasuteis.com.br/escala/ [R=301,L,NC]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Legacy explicit redirects (.html -> clean route)
RewriteRule ^calcular\.html$ /calcular/ [R=301,L,NC]
RewriteRule ^calendario\.html$ /calendario/ [R=301,L,NC]
RewriteRule ^escala\.html$ /escala/ [R=301,L,NC]

# Generic legacy .html redirects, except root index.html
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html(?:[\s?]|$) [NC]
RewriteCond %1 !^index$ [NC]
RewriteRule ^ /%1/ [R=301,L,NE]

# Canonical /path/index.html -> /path/
RewriteRule ^(.*/)?index\.html$ /$1 [R=301,L,NC]

# Cache headers for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType image/svg+xml "access plus 365 days"
  ExpiresByType image/png "access plus 365 days"
  ExpiresByType image/jpeg "access plus 365 days"
  ExpiresByType image/webp "access plus 365 days"
  ExpiresByType font/woff2 "access plus 365 days"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|svg|png|jpe?g|webp|woff2)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>

  <FilesMatch "\.json$">
    Header set Cache-Control "max-age=86400, public"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
